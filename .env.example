# Required: Discord bot token for the server
DISCORD_TOKEN=

# Required: Shared auth token (from ~/.cc-hub/config.json "token" field)
CC_HUB_TOKEN=

# Optional: Claude dev container image
# CLAUDE_IMAGE=ghcr.io/rophy/containers/claude:20260323-bc35380

# Optional: Host UID/GID for the node-agent container
# HOST_UID=1000
# HOST_GID=1000

# Optional: Docker group GID (for node-agent docker socket access)
# Find with: getent group docker | cut -d: -f3
# DOCKER_GID=990

# Optional: Root directory containing projects (mounted into node-agent at same path)
# Defaults to $HOME/projects
# PROJECTS_DIR=/home/user/projects
